# 운영 → 개발 DB 일일 동기화 (prod-to-dev-daily.sh)
# 복사: sudo cp prod-to-dev-daily.env.example /etc/mindgarden/prod-to-dev-sync.env
# 권한: sudo chmod 600 /etc/mindgarden/prod-to-dev-sync.env
#
# 실행 서버: 운영 DB에 네트워크로 접속 가능하고, 개발 DB에 쓰기 가능한 호스트(점프/배치 전용) 권장.
# 스케줄: cron으로 매일 새벽 권장 — scripts/database/sync/crontab.example (CRON_TZ=Asia/Seoul, 예: 03:30)
# 비밀번호는 파일에 평문 저장 지양 → mysql_config_editor 또는 별도 secrets manager 권장.

# --- 동기 모드 ---
# dump_live: 실행 시점 운영 DB를 mysqldump → 개발 DB에 직접 적재 (네트워크·권한 필요)
# from_file: 전일( D-1 ) 날짜가 이름에 포함된 덤프 파일을 디렉터리에서 찾아 개발 DB에 적재 (운영 측 일일 덤프 배치가 선행되어야 함)
SYNC_MODE=dump_live

# from_file 일 때: 전일 덤프 파일 경로 패턴의 디렉터리
# 파일명 예: mind_garden_20260408.sql.gz (전일 2026-04-08)
#DUMP_DIR=/home/backup/database/daily
#DUMP_FILE_PREFIX=mind_garden_

# --- 운영 (소스) ---
PROD_MYSQL_HOST=prod-mysql.example.com
PROD_MYSQL_PORT=3306
PROD_MYSQL_USER=readonly_or_dump_user
# PROD_MYSQL_PASSWORD=  # 가능하면 미사용; ~/.my.cnf 또는 환경별 시크릿 주입
PROD_DB_NAME=mind_garden

# --- 개발 (타깃) ---
DEV_MYSQL_HOST=dev-mysql.example.com
DEV_MYSQL_PORT=3306
DEV_MYSQL_USER=root
# DEV_MYSQL_PASSWORD=
DEV_DB_NAME=mind_garden_dev

# --- 동작 ---
# cron 실행 시 필수 (대화형 확인 생략)
NON_INTERACTIVE=1

# 운영 덤프 계정에 SHOW ROUTINE 권한이 없어 mysqldump가 실패할 때 1 (프로시저는 배포/Flyway로 보완)
#DUMP_SKIP_ROUTINES=1

# 덤프·로그 (디스크 여유 확인)
TMP_DIR=/var/tmp
LOG_DIR=/var/log/mindgarden
RETAIN_LOCAL_DUMPS=1

# 덤프 후 개발 DB에 추가 실행할 SQL (선택, Flyway repair 등)
# POST_SYNC_SQL_FILE=/opt/mindgarden/scripts/database/sync/post-dev-sync.sql
