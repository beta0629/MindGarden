import React, { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { apiGet } from '../../../../utils/ajax';
import StatCard from '../../../ui/Card/StatCard';
import MGButton from '../common/MGButton';
import { WIDGET_CONSTANTS } from '../../../../constants/widgetConstants';
import { MG_DESIGN_TOKENS } from '../../../../constants/designTokens';
import '../Widget.css';
import '../../../../styles/unified-design-tokens.css';

/**
 * 입금 확인 대기 목록을 보여주는 위젯
 * 
 * @param {Object} widget - 위젯 설정 정보
 * @param {Object} user - 현재 사용자 정보
 * @returns {JSX.Element}
 */
const PendingDepositsWidget = ({ widget, user }) => {
  const navigate = useNavigate();
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  const config = widget.config || {};

  useEffect(() => {
    loadData();
  }, []);

  const loadData = async () => {
    try {
      setLoading(true);
      setError(null);
      
      // 단일 API 호출
      const response = await apiGet('/api/admin/pending-deposits');
      setData(response);
    } catch (err) {
      console.error('PendingDepositsWidget 데이터 로드 실패:', err);
      setError(err.message);
    } finally {
      setLoading(false);
    }
  };

    if (loading) {
    return (
      <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_CONTAINER('pending-deposits')}>
        <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_HEADER}>
          <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_CARD_HEADER}>
            <h3 className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_TITLE}>
              {config.title || WIDGET_CONSTANTS.DEFAULT_TITLES.PENDING_DEPOSITS}
            </h3>
          </div>
        </div>
        <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_BODY}>
          <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_CARD_BODY}>
            <div className={WIDGET_CONSTANTS.CSS_CLASSES.LOADING_CONTAINER}>
              <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_LOADING_SPINNER}></div>
              <p className={WIDGET_CONSTANTS.CSS_CLASSES.MG_TEXT_MUTED}>
                {WIDGET_CONSTANTS.LOADING_MESSAGES.DEFAULT}
              </p>
            </div>
          </div>
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_CONTAINER('pending-deposits')}>
        <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_HEADER}>
          <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_CARD_HEADER}>
            <h3 className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_TITLE}>
              {config.title || WIDGET_CONSTANTS.DEFAULT_TITLES.PENDING_DEPOSITS}
            </h3>
          </div>
        </div>
        <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_BODY}>
          <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_CARD_BODY}>
            <div className={WIDGET_CONSTANTS.CSS_CLASSES.ERROR_CONTAINER}>
              <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_ALERT_ERROR}>
                <span className={WIDGET_CONSTANTS.CSS_CLASSES.MG_ALERT_ICON}>⚠️</span>
                <span className={WIDGET_CONSTANTS.CSS_CLASSES.MG_ALERT_MESSAGE}>
                  {WIDGET_CONSTANTS.ERROR_MESSAGES.LOAD_FAILED}: {error}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_CONTAINER('pending-deposits')}>
      <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_HEADER}>
        <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_CARD_HEADER}>
          <h3 className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_TITLE}>
            {config.title || WIDGET_CONSTANTS.DEFAULT_TITLES.PENDING_DEPOSITS}
          </h3>
          {config.subtitle && (
            <p className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_SUBTITLE}>
              {config.subtitle}
            </p>
          )}
        </div>
      </div>
      <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_BODY}>
        <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_CARD_BODY}>
          {/* TODO: 위젯 내용 구현 - MindGarden 디자인 시스템 사용 */}
          <div className={WIDGET_CONSTANTS.CSS_CLASSES.WIDGET_CONTENT}>
            {/* 예시: StatCard 사용 */}
            <div className={WIDGET_CONSTANTS.CSS_CLASSES.MG_STATS_GRID}>
              <StatCard
                icon={<span>📊</span>}
                value={data?.count || 0}
                label="데이터 수"
                color={MG_DESIGN_TOKENS.COLORS.PRIMARY}
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default PendingDepositsWidget;
