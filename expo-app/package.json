{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.7",
  "scripts": {
    "prestart": "npm run verify:metro-mmkv",
    "prestart:clean": "npm run verify:metro-mmkv",
    "dev": "bash ./scripts/dev-app.sh",
    "dev:clean": "bash ./scripts/dev-app.sh --clean --kill-stale",
    "dev:android": "bash ./scripts/dev-app.sh --clean --kill-stale --android",
    "dev:ios": "bash ./scripts/dev-app.sh --clean --kill-stale --ios",
    "dev:metro-url": "node ./scripts/print-metro-lan-url.js",
    "start": "node ./scripts/run-expo.js start",
    "start:clean": "node ./scripts/run-expo.js start --clear",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify:metro-mmkv": "node ./scripts/verify-metro-mmkv.js",
    "verify:bundle:ci": "npm run verify:metro-mmkv && CI=1 npx expo export --platform web --output-dir /tmp/mg-expo-ci-web",
    "test:utils": "jest --config jest.config.cjs",
    "start:localhost": "node ./scripts/run-expo.js start --localhost",
    "start:lan": "node ./scripts/run-expo.js start --lan",
    "start:tunnel": "node ./scripts/run-expo.js start --tunnel",
    "adb:reverse-metro": "node ./scripts/adb-reverse-metro-port.js",
    "adb:reverse-metro:all": "node ./scripts/adb-reverse-metro-all.js",
    "ios:metro-localhost": "xcrun simctl openurl booted \"mindgarden://expo-development-client/?url=http%3A%2F%2F127.0.0.1%3A8081\"",
    "android": "expo run:android",
    "android:apk:dev": "bash ./scripts/build-android-apk-dev.sh",
    "ios:eas:internal-dev": "bash ./scripts/build-ios-eas-internal-dev.sh",
    "android:apk:standalone": "npm run android:apk:dev",
    "android:apk:install": "node ./scripts/install-android-release-apk.js",
    "android:apk:dev:install": "npm run android:apk:dev && npm run android:apk:install",
    "release:archive-dev-apk": "node ./scripts/archive-release-apk.js dev",
    "ios": "expo run:ios",
    "web": "node ./scripts/run-expo.js start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-native-seoul/kakao-login": "^5.4.2",
    "@react-native-seoul/naver-login": "^4.2.4",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-sync-storage-persister": "^5.100.10",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-persist-client": "^5.100.10",
    "axios": "^1.16.0",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-audio": "~1.1.1",
    "expo-background-fetch": "~14.0.9",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-calendar": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
