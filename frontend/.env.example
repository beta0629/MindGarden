# Core 프론트 로컬 개발용. 이 파일을 복사해 `.env.local` 등으로 사용하세요.
# 프로덕션 빌드: 민감 값은 CI/호스트 시크릿의 REACT_APP_* 만 사용(코드·저장소 폴백 없음).

# API (로컬 백엔드 직접 호출 시)
# REACT_APP_API_BASE_URL=http://localhost:8080

# OAuth — 실제 값은 각 개발자 콘솔에서 발급
# REACT_APP_KAKAO_CLIENT_ID=
# REACT_APP_KAKAO_REDIRECT_URI=http://localhost:3000/api/v1/auth/kakao/callback

# REACT_APP_NAVER_CLIENT_ID=
# REACT_APP_NAVER_CLIENT_SECRET=
# REACT_APP_NAVER_REDIRECT_URI=http://localhost:3000/api/v1/auth/naver/callback

# REACT_APP_GOOGLE_CLIENT_ID=
# REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
# 웹 GIS(Google Identity Services) 통합용 별칭 — `@react-oauth/google` Provider 에 주입.
# REACT_APP_GOOGLE_CLIENT_ID 와 동일 값. 둘 중 하나만 설정해도 인식된다.
# REACT_APP_GOOGLE_WEB_CLIENT_ID=

# REACT_APP_FACEBOOK_CLIENT_ID=
# REACT_APP_FACEBOOK_REDIRECT_URI=http://localhost:3000/api/v1/auth/facebook/callback

# Sign in with Apple (App Store 4.8 T1) — Apple JS SDK 웹 통합용 공개 클라이언트 키.
# - REACT_APP_APPLE_CLIENT_ID: Apple Developer Console 의 Service ID (예: co.kr.coresolution.app.signin)
# - REACT_APP_APPLE_REDIRECT_URI: Service ID 에 등록한 Return URL — 백엔드 콜백 라우트와 일치해야 함
# REACT_APP_APPLE_CLIENT_ID=
# REACT_APP_APPLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/apple/callback

# REACT_APP_FRONTEND_URL=http://localhost:3000
