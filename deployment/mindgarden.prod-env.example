# MindGarden systemd EnvironmentFile= 예시
# 복사: sudo cp mindgarden.prod-env.example /etc/mindgarden/mindgarden.env && sudo chmod 600 ...
# 서비스: EnvironmentFile=-/etc/mindgarden/mindgarden.env
#
# OAuth: NAVER_REDIRECT_URI 미지정 시 server.base-url 사용. 네이버·카카오 콘솔 Callback과 동일 호스트 필수.
#   운영 권장: OAUTH2_BASE_URL=https://core-solution.co.kr , SERVER_BASE_URL=https://core-solution.co.kr
#   (테넌트 mindgarden.core-solution.co.kr 가 아님 — 멀티테넌트는 apex 콜백 1개 패턴)
# FRONTEND_BASE_URL: 사용자 SPA (예 https://mindgarden.core-solution.co.kr)
# 저장소에는 실비밀·실키를 넣지 말고 값은 비우거나 배포 호스트에서만 채움.

OAUTH2_BASE_URL=
FRONTEND_BASE_URL=
SERVER_BASE_URL=
# 테넌트 서브도메인 + apex OAuth 콜백 패턴에서 필수에 가깝다(미설정 시 로그인 직후 mindgarden.* 에서 401 반복 가능).
# 값: 공유할 상위 호스트만(RFC 6265 Cookie Domain: 선행 점(.) 없이 reg-name 형태, 예 core-solution.co.kr).
SESSION_COOKIE_DOMAIN=core-solution.co.kr

DB_USERNAME=
DB_PASSWORD=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

JWT_SECRET=
PERSONAL_DATA_ENCRYPTION_KEY=
PERSONAL_DATA_ENCRYPTION_IV=
PSYCH_DOC_KEY_B64=

SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

PAYMENT_TOSS_SECRET_KEY=
PAYMENT_IAMPORT_API_KEY=
PAYMENT_IAMPORT_API_SECRET=

KAKAO_ALIMTALK_API_KEY=
KAKAO_ALIMTALK_SENDER_KEY=

SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_NUMBER=

# 블루그린(듀얼 systemd) 사용 시: 포트는 각 유닛의 Environment=SERVER_PORT 로만 두고, 여기서는 비워 두는 것을 권장.
# 단일 mindgarden.service 만 쓸 때만 필요 시 설정.
SERVER_PORT=
SPRING_PROFILES_ACTIVE=

SSL_KEYSTORE_PATH=
SSL_KEYSTORE_PASSWORD=
SSL_KEY_ALIAS=
