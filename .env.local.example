# 홈페이지 로컬 개발용 — 복사: cp .env.local.example .env.local
# 상담 알림 메일: ~/mindGarden/src/main/resources/application-local.yml 의 spring.mail.* 와 동일 값을 넣으면 코어와 같은 Gmail SMTP로 발송됩니다.
# (비밀번호는 저장소에 커밋하지 마세요.)

CONSULTATION_ADMIN_NOTIFY_EMAILS=본인_메일@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=코어_application-local.yml의_spring.mail.username_와_동일
SMTP_PASSWORD=코어의_spring.mail.password_와_동일_Git에_넣지_않음
# SMTP_USER=   # SMTP_USERNAME 과 택일(코드에서 둘 다 지원)
# MAIL_FROM=발신에_쓰는_Gmail_주소
# SMTP_SECURE=true   # 포트 465 SSL 시
# SMTP_REQUIRE_TLS=false   # 로컬 릴레이 등 STARTTLS 불필 시만
