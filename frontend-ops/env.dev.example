# Trinity Ops Portal Frontend – 개발 서버 환경 예시
# 배포 시 .env.dev 으로 복사하거나 배포 환경 변수에 등록하세요.

# API Base URL 설정 (개발 서버 도메인)
NEXT_PUBLIC_OPS_API_BASE_URL=https://ops.dev.e-trinity.co.kr/api/v1
NEXT_PUBLIC_CORE_API_BASE_URL=https://api.dev.core-solution.co.kr/api/v1  # CoreSolution API (필요시)
NEXT_PUBLIC_OPS_API_USE_MOCK=false

# (옵션) 자동 테스트/Mock 에서 토큰을 직접 주입하고 싶을 때만 사용
# NEXT_PUBLIC_OPS_API_TOKEN=dev-placeholder-token
# NEXT_PUBLIC_OPS_ACTOR_ID=dev-ops-admin
# NEXT_PUBLIC_OPS_ACTOR_ROLE=HQ_ADMIN

