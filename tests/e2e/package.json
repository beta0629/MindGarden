{
  "name": "mindgarden-e2e-tests",
  "version": "1.0.0",
  "description": "MindGarden E2E 테스트 자동화",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:admin": "playwright test tests/admin",
    "test:consultant": "playwright test tests/consultant",
    "test:client": "playwright test tests/client",
    "test:erp:chromium": "playwright test tests/erp/erp-legacy-path-redirects.spec.ts --project=chromium && playwright test tests/erp/erp-approval-hub-redirect.spec.ts --grep \"super-approvals\" --project=chromium",
    "test:erp:chromium:all": "playwright test tests/erp --project=chromium",
    "test:dev": "BASE_URL=https://mindgarden.dev.core-solution.co.kr playwright test tests/admin/psych-assessments-after-login.spec.ts --config=playwright.manual.config.ts --project=chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}