# MindGarden 개발 서버 환경 변수

# 서버/도메인 설정 (표준화: 신규 도메인 사용)
SERVER_BASE_URL=https://dev.core-solution.co.kr
FRONTEND_BASE_URL=https://mindgarden.dev.core-solution.co.kr
CORS_ALLOWED_ORIGINS=https://mindgarden.dev.core-solution.co.kr,https://dev.core-solution.co.kr

# OAuth2: 로그인 성공 후 리다이렉트할 프론트 URL (서브도메인 가능)
OAUTH2_BASE_URL=https://mindgarden.dev.core-solution.co.kr

# 세션 쿠키 도메인: 루트 도메인(dev) 콜백 사용 시, 서브도메인(mindgarden 등)에서도 JSESSIONID 공유
# RFC 6265: 선행 점(.)은 invalid → dev.core-solution.co.kr 만 사용 (서브도메인은 자동 포함)
SESSION_COOKIE_DOMAIN=dev.core-solution.co.kr

# 데이터베이스 설정 (개발 DB)
DB_HOST=beta0629.cafe24.com
DB_PORT=3306
DB_NAME=core_solution
DB_USERNAME=mindgarden_dev
DB_PASSWORD=MindGardenDev2025!@#

# OAuth2 - Kakao (콜백은 루트 도메인, 세션 쿠키 Domain=dev.core-solution.co.kr 로 서브도메인 공유)
KAKAO_CLIENT_ID=cbb457cfb5f9351fd495be4af2b11a34
KAKAO_CLIENT_SECRET=LH53SXuqZk7iEVeDkKfQuKxW0sdxYmEG
KAKAO_REDIRECT_URI=https://dev.core-solution.co.kr/api/auth/kakao/callback

# OAuth2 - Naver (콜백은 루트 도메인, 세션 쿠키 Domain=dev.core-solution.co.kr 로 서브도메인 공유)
NAVER_CLIENT_ID=vTKNlxYKIfo1uCCXaDfk
NAVER_CLIENT_SECRET=V_b3omW5pu
NAVER_REDIRECT_URI=https://dev.core-solution.co.kr/api/auth/naver/callback

# Spring Security / OAuth2 자동 설정 비활성화 (application-dev.yml에서도 exclude 되어 있지만 중복 설정)
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_AUTHORIZATION_GRANT_TYPE=authorization_code
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_NAVER_AUTHORIZATION_GRANT_TYPE=authorization_code
SPRING_AUTOCONFIGURE_EXCLUDE=org.springframework.boot.autoconfigure.security.oauth2.client.servlet.OAuth2ClientAutoConfiguration

# JWT (개발용)
JWT_SECRET=dev-jwt-secret-key-for-development-server-only

