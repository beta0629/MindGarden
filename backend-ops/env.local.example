# Trinity Ops Backend – 로컬 환경 예시
# 사용법: cp env.local.example .env.local

# JWT 설정 (최소 32자 이상 필수 - 256비트)
SECURITY_JWT_SECRET=local-dev-secret-key-must-be-at-least-32-characters-long-for-hs256-algorithm
SECURITY_JWT_ISSUER=mindgarden-ops-local
SECURITY_JWT_EXPIRES=3600

# 관리자 계정 설정
OPS_ADMIN_USERNAME=ops_core
OPS_ADMIN_PASSWORD=godgod826!
OPS_ADMIN_ROLE=HQ_ADMIN

# 서버 포트 설정
SERVER_PORT=8081  # 로컬: 8081 (CoreSolution 8080과 분리)

# CORS 설정 (로컬 개발)
OPS_CORS_ALLOWED_ORIGINS=http://localhost:4300

