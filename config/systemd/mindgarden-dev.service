[Unit]
Description=MindGarden Development Server
After=network.target mysql.service

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/mindgarden-dev
# 세션 쿠키 도메인 등 OAuth/세션 env 로드 (파일 없으면 무시: -)
EnvironmentFile=-/etc/mindgarden/dev.env
# JVM 힙 설정 (AnomalyDetectionService 메모리 경고 방지)
Environment=JAVA_OPTS="-Xms1g -Xmx4g -XX:+UseG1GC"
ExecStart=/opt/mindgarden/start.sh
Restart=always
RestartSec=10
TimeoutStartSec=120
SyslogIdentifier=mindgarden-dev
# stdout/stderr 모두 journal + 파일에 남기기 (journalctl과 dev-error.log에서 예외 확인 가능)
StandardOutput=append:/var/log/mindgarden/dev.log
StandardError=append:/var/log/mindgarden/dev-error.log

[Install]
WantedBy=multi-user.target


