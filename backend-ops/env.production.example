# Trinity Ops Backend (Ops Portal) – 운영 환경 예시
# systemd 서비스 또는 CI/CD 시크릿에 등록해 사용하세요.

# 데이터베이스 설정
MG_DB_URL=jdbc:postgresql://prod-db.mindgarden.internal:5432/mindgarden_ops_db
MG_DB_USERNAME=ops_service_user
MG_DB_PASSWORD=__REPLACE_ME__

# JWT 설정
SECURITY_JWT_SECRET=__REPLACE_ME_WITH_32_CHAR_SECRET__
SECURITY_JWT_ISSUER=https://identity.e-trinity.co.kr/realms/trinity-ops
SECURITY_JWT_EXPIRES=3600

# 관리자 계정 설정 (SSO 도입 전 임시)
OPS_ADMIN_USERNAME=ops-admin
OPS_ADMIN_PASSWORD=__SET_IN_SECRET_MANAGER__
OPS_ADMIN_ROLE=HQ_ADMIN

# 서버 포트 설정
SERVER_PORT=8080  # 운영 서버: 8080 (Nginx 프록시와 일치)

# CORS 설정 (운영 서버 도메인)
OPS_CORS_ALLOWED_ORIGINS=https://ops.e-trinity.co.kr

