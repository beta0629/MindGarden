# Solapi SMS — 로컬 전용 (Git 커밋 금지)
# 사용: cp config/environments/sms.local.env.example config/environments/sms.local.env
#       값 채운 뒤: bash scripts/deployment/sync-solapi-sms-env.sh

SMS_PROVIDER=solapi
SMS_AUTH_ENABLED=true

# 솔라피 콘솔 API Key / Secret (필수)
SMS_API_KEY=
SMS_API_SECRET=

# 발신번호 — 비우면 서버에 이미 있는 SMS_SENDER_NUMBER 유지
SMS_SENDER_NUMBER=
