# MindGarden — 운영→개발 DB 일일 동기화 (새벽 권장)
# 적용: crontab -e 복사 또는 배치 전용 유저 crontab
#
# 스크립트 경로는 배포 위치에 맞게 수정하세요.

# 서버 시스템 타임존이 UTC 등이면 아래 한 줄로 “한국 새벽” 기준 실행 (cronie 등 지원)
CRON_TZ=Asia/Seoul

# 매일 새벽 03:30 에 실행 (전일 업무 반영·운영 부하 최소 시간대)
30 3 * * * NON_INTERACTIVE=1 /opt/mindgarden/scripts/database/sync/prod-to-dev-daily.sh >> /var/log/mindgarden/prod-to-dev-cron.log 2>&1
