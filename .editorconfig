# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{java,jsp,xml}]
indent_size = 4
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{sh,bat}]
end_of_line = lf
indent_size = 4

[*.sql]
indent_size = 2
max_line_length = 120

[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

[*.{css,scss,less}]
indent_size = 2
max_line_length = 120

[Makefile]
indent_style = tab

[*.{properties,conf}]
indent_size = 4


