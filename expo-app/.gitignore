# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
.cache/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env (비밀·키는 커밋 금지 — 템플릿은 .env.example)
.env
.env.local
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# 로컬에서 말아 둔 dev API 릴리스 APK (재빌드 시 덮어씀)
mindgarden-dev-release.apk

# 릴리즈 아티팩트 바이너리 (Git에는 manifest·README·.gitkeep만)
releases/artifacts/*
!releases/artifacts/.gitkeep
