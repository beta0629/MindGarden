# MindGarden expo-app — 복사: cp .env.example .env
# .env 는 git에 올리지 않는다.
# 카카오·네이버 소셜 로그인을 쓰려면 아래 블록을 모두 채우는 것을 권장한다.

# --- 카카오 (네이티브 앱 키) ---
# prebuild / `expo run:ios|android` 시 app.config의 @react-native-seoul/kakao-login 플러그인에 주입됨.
# 레거시 RN 앱과 동일하게 쓰려면: mobile/ios/MindGardenMobile/Info.plist 의 KAKAO_APP_KEY 값과 동일.
KAKAO_APP_KEY=

# --- 네이버 (네이티브 플러그인 — app.config 의 naver-login + iOS infoPlist NAVER_*) ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 네이버 (JS 런타임 — AuthService.initialize) ---
# EXPO_PUBLIC_* 는 번들에 포함되므로, 모바일 앱에 노출돼도 되는 클라이언트 ID/Secret 만.
EXPO_PUBLIC_NAVER_CLIENT_ID=
EXPO_PUBLIC_NAVER_CLIENT_SECRET=

# --- EAS / Expo Push (기기 ExponentPushToken[...]) ---
# UUID: expo.dev → mindgarden 프로젝트 → General → Project ID
# prebuild·`npm run android:apk:dev`·EAS iOS 빌드 시 app.config `extra.eas.projectId` 에 주입. `.env` 는 커밋 금지.
# Android FCM: Firebase Console → 앱(com.mindgardenmobile) → google-services.json → expo-app/google-services.json (커밋 금지)
#   + Expo 대시보드 Credentials → Android → FCM V1 (§ MOBILE_PUSH_EXPO_DEPLOYMENT_CHECKLIST §2.2)
# iOS APNs: Apple Developer App ID Push ON → APNs Auth Key(.p8) → Expo Credentials → iOS → Push Key (§2.3, .p8 커밋 금지)
#   실기기/TestFlight 필수 — 시뮬레이터는 ExponentPushToken 불안정. 서버 발송은 Android와 동일 EXPO_ACCESS_TOKEN 만.
EAS_PROJECT_ID=
EXPO_PUBLIC_EAS_PROJECT_ID=

# --- 선택: 토스·기타 ---
# EXPO_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
# EXPO_PUBLIC_TOSS_PAYMENT_SUCCESS_URL=
# EXPO_PUBLIC_TOSS_PAYMENT_FAIL_URL=
# EXPO_PUBLIC_SESSION_EXTENSION_CATALOG_JSON=

# --- Sign in with Apple (App Store 4.8 T1) ---
# Apple `expo-apple-authentication` 은 디바이스의 Apple ID 기반이라 클라이언트 env 가 필요 없다.
# iOS 빌드 시점에 Bundle ID(`com.mindgarden.MindGardenMobile`) 가 SIWA Capability 와 매칭된다.
# 운영 환경에서 백엔드가 사용하는 5종 env (APPLE_CLIENT_ID/TEAM_ID/KEY_ID/PRIVATE_KEY/REDIRECT_URI) 는
# 백엔드 서버 환경변수 또는 GitHub Actions secret 에만 주입한다.
# 운영 주입 가이드: docs/project-management/2026-06-04/APPLE_T1_OPS_ENV_INJECTION_GUIDE.md
