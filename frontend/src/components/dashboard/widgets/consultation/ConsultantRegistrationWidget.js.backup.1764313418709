/**
 * Consultant Registration Widget
 * 상담소 특화 상담사 등록 위젯
 * 
 * @author CoreSolution
 * @version 1.0.0
 * @since 2025-11-25
 */

import React, { useState } from 'react';
import { apiPost } from '../../../../utils/ajax';
import notificationManager from '../../../../utils/notification';
import UnifiedLoading from '../../../../components/common/UnifiedLoading';
import '../Widget.css';

const ConsultantRegistrationWidget = ({ widget, user }) => {
  const [loading, setLoading] = useState(false);
  const [showForm, setShowForm] = useState(false);
  const [formData, setFormData] = useState({
    username: '',
    email: '',
    password: '',
    name: '',
    phone: '',
    address: '',
    addressDetail: '',
    postalCode: '',
    specialization: '',
    qualifications: '',
    notes: ''
  });

  const config = widget.config || {};
  const title = config.title || '상담사 등록';
  const showCompactForm = config.showCompactForm !== false; // 기본값: true (간단한 폼)
  const autoCloseAfterSubmit = config.autoCloseAfterSubmit !== false; // 기본값: true

  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({
      ...prev,
      [name]: value
    }));
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    
    if (!formData.username || !formData.name || !formData.email || !formData.password || !formData.phone) {
      notificationManager.show('필수 항목을 모두 입력해주세요.', 'warning');
      return;
    }

    setLoading(true);
    try {
      const requestData = {
        username: formData.username,
        email: formData.email,
        password: formData.password,
        name: formData.name,
        phone: formData.phone,
        role: 'ROLE_CONSULTANT',
        ...(formData.address && { address: formData.address }),
        ...(formData.addressDetail && { addressDetail: formData.addressDetail }),
        ...(formData.postalCode && { postalCode: formData.postalCode }),
        ...(formData.specialization && { specialization: formData.specialization }),
        ...(formData.qualifications && { qualifications: formData.qualifications }),
        ...(formData.notes && { notes: formData.notes })
      };

      const response = await apiPost('/api/admin/consultants', requestData);
      
      if (response) {
        notificationManager.show('상담사가 성공적으로 등록되었습니다.', 'success');
        
        // 폼 초기화
        setFormData({
          username: '',
          email: '',
          password: '',
          name: '',
          phone: '',
          address: '',
          addressDetail: '',
          postalCode: '',
          specialization: '',
          qualifications: '',
          notes: ''
        });

        // 자동 닫기 옵션
        if (autoCloseAfterSubmit) {
          setShowForm(false);
        }

        // 위젯 새로고침 이벤트 발생 (부모 컴포넌트에서 처리)
        if (config.onSuccess) {
          config.onSuccess(response);
        }
      }
    } catch (error) {
      console.error('❌ 상담사 등록 실패:', error);
      notificationManager.show(
        error.message || '상담사 등록 중 오류가 발생했습니다.',
        'error'
      );
    } finally {
      setLoading(false);
    }
  };

  const handleReset = () => {
    setFormData({
      username: '',
      email: '',
      password: '',
      name: '',
      phone: '',
      address: '',
      addressDetail: '',
      postalCode: '',
      specialization: '',
      qualifications: '',
      notes: ''
    });
  };

  if (loading) {
    return (
      <div className="widget widget-consultant-registration">
        <UnifiedLoading message="등록 중..." />
      </div>
    );
  }

  return (
    <div className="widget widget-consultant-registration">
      <div className="widget-header">
        <div className="widget-title">
          <i className="bi bi-person-badge"></i>
          {title}
        </div>
        {!showForm && (
          <button 
            className="widget-btn widget-btn-primary widget-btn-sm"
            onClick={() => setShowForm(true)}
          >
            <i className="bi bi-plus-circle"></i> 등록
          </button>
        )}
      </div>

      {showForm ? (
        <div className="widget-body">
          <form onSubmit={handleSubmit} className="widget-form">
            {/* 필수 항목 */}
            <div className="form-group">
              <label htmlFor="username" className="form-label">
                아이디 <span className="text-danger">*</span>
              </label>
              <input
                type="text"
                id="username"
                name="username"
                value={formData.username}
                onChange={handleInputChange}
                required
                className="form-control"
                placeholder="로그인 아이디"
              />
            </div>

            <div className="form-group">
              <label htmlFor="name" className="form-label">
                이름 <span className="text-danger">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                value={formData.name}
                onChange={handleInputChange}
                required
                className="form-control"
              />
            </div>

            <div className="form-group">
              <label htmlFor="email" className="form-label">
                이메일 <span className="text-danger">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                value={formData.email}
                onChange={handleInputChange}
                required
                className="form-control"
              />
            </div>

            <div className="form-group">
              <label htmlFor="password" className="form-label">
                비밀번호 <span className="text-danger">*</span>
              </label>
              <input
                type="password"
                id="password"
                name="password"
                value={formData.password}
                onChange={handleInputChange}
                required
                className="form-control"
                placeholder="로그인 비밀번호"
              />
            </div>

            <div className="form-group">
              <label htmlFor="phone" className="form-label">
                전화번호 <span className="text-danger">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                value={formData.phone}
                onChange={handleInputChange}
                required
                className="form-control"
                placeholder="010-1234-5678"
              />
            </div>

            {/* 간단한 폼이 아닌 경우 추가 필드 표시 */}
            {!showCompactForm && (
              <>
                <div className="form-group">
                  <label htmlFor="address" className="form-label">주소</label>
                  <input
                    type="text"
                    id="address"
                    name="address"
                    value={formData.address}
                    onChange={handleInputChange}
                    className="form-control"
                    placeholder="기본 주소"
                  />
                </div>

                <div className="form-group">
                  <label htmlFor="addressDetail" className="form-label">상세 주소</label>
                  <input
                    type="text"
                    id="addressDetail"
                    name="addressDetail"
                    value={formData.addressDetail}
                    onChange={handleInputChange}
                    className="form-control"
                    placeholder="상세 주소"
                  />
                </div>

                <div className="form-group">
                  <label htmlFor="postalCode" className="form-label">우편번호</label>
                  <input
                    type="text"
                    id="postalCode"
                    name="postalCode"
                    value={formData.postalCode}
                    onChange={handleInputChange}
                    className="form-control"
                    placeholder="12345"
                  />
                </div>

                <div className="form-group">
                  <label htmlFor="specialization" className="form-label">전문분야</label>
                  <input
                    type="text"
                    id="specialization"
                    name="specialization"
                    value={formData.specialization}
                    onChange={handleInputChange}
                    className="form-control"
                    placeholder="예: 스트레스, 불안, 우울증"
                  />
                </div>

                <div className="form-group">
                  <label htmlFor="qualifications" className="form-label">자격증</label>
                  <input
                    type="text"
                    id="qualifications"
                    name="qualifications"
                    value={formData.qualifications}
                    onChange={handleInputChange}
                    className="form-control"
                    placeholder="예: 상담심리사 1급, 임상심리사"
                  />
                </div>

                <div className="form-group">
                  <label htmlFor="notes" className="form-label">메모</label>
                  <textarea
                    id="notes"
                    name="notes"
                    value={formData.notes}
                    onChange={handleInputChange}
                    className="form-control"
                    rows={3}
                    placeholder="추가 메모"
                  />
                </div>
              </>
            )}

            <div className="form-actions">
              <button
                type="button"
                className="widget-btn widget-btn-secondary"
                onClick={() => {
                  setShowForm(false);
                  handleReset();
                }}
              >
                취소
              </button>
              <button
                type="button"
                className="widget-btn widget-btn-secondary"
                onClick={handleReset}
              >
                초기화
              </button>
              <button
                type="submit"
                className="widget-btn widget-btn-primary"
              >
                <i className="bi bi-check-circle"></i> 등록
              </button>
            </div>
          </form>
        </div>
      ) : (
        <div className="widget-body">
          <div className="widget-empty">
            <i className="bi bi-person-badge"></i>
            <p>{config.emptyMessage || '상담사 등록 버튼을 클릭하여 새 상담사를 등록하세요.'}</p>
          </div>
        </div>
      )}
    </div>
  );
};

export default ConsultantRegistrationWidget;


