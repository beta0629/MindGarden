# 운영: PM2(ecosystem.homepage.config.cjs)는 /var/www/homepage/.env 만 로드한다.
#   로컬에서 채운 뒤 서버에 .env 로 업로드(또는 ssh 상에서 vi). 파일명 .env.production 은 이 경로에서 쓰이지 않음.
# 개발과 동일한 DB 계정·비밀번호를 쓰고, DB_HOST 만 운영 DB 주소(또는 127.0.0.1)로 둔다.

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://m-garden.co.kr
PORT=4000
NEXT_PUBLIC_PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=homepage_user
DB_PASSWORD=여기에_운영과_동일한_비밀번호
DB_NAME=core_solution

BLOG_ADMIN_PASSWORD=운영용_강한_비밀번호로_변경

# 상담 접수 시 관리자 알림 — 코어와 같은 SMTP (참고: ~/mindGarden)
# 로컬: mindGarden/src/main/resources/application-local.yml 의 spring.mail.host|port|username|password
# 운영: mindGarden/src/main/resources/application-prod.yml 의 production.mail → SMTP_HOST, SMTP_PORT, SMTP_USERNAME, SMTP_PASSWORD
# 비밀번호는 Git에 넣지 말고 서버 Secrets 또는 .env.local 만 사용.
# spring.mail.username      → SMTP_USER 또는 SMTP_USERNAME (운영 코어와 동일 변수명)
# spring.mail.password      → SMTP_PASSWORD
# 발신 표시                 → MAIL_FROM (미설정 시 계정과 동일)
# 465 SSL                   → SMTP_SECURE=true
# 로컬 릴레이 등 TLS 불필 → SMTP_REQUIRE_TLS=false
# DB(homepage_settings)에 수신 주소가 있으면 그 목록이 우선. 없을 때만 아래 env 사용.
CONSULTATION_ADMIN_NOTIFY_EMAILS=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SMTP_USER=   # SMTP_USERNAME 과 택일
# MAIL_FROM=noreply@mindgarden.co.kr
