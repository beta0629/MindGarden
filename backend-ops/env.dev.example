# Trinity Ops Backend – 개발 서버 환경 예시
# 사용법: cp env.dev.example .env.dev 또는 systemd 서비스 환경 변수에 등록

# 데이터베이스 설정
DB_HOST=beta0629.cafe24.com
DB_PORT=3306
DB_NAME=core_solution
DB_USERNAME=mindgarden_dev
DB_PASSWORD=MindGardenDev2025!@#

# JWT 설정
SECURITY_JWT_SECRET=dev-jwt-secret-key-for-development-server-only
SECURITY_JWT_ISSUER=mindgarden-ops
SECURITY_JWT_EXPIRES=3600

# 관리자 계정 설정
OPS_ADMIN_USERNAME=ops_core
OPS_ADMIN_PASSWORD=godgod826!
OPS_ADMIN_ROLE=HQ_ADMIN

# 서버 포트 설정
SERVER_PORT=8080  # 개발 서버: 8080 (Nginx 프록시와 일치)

# CORS 설정 (개발 서버 도메인)
OPS_CORS_ALLOWED_ORIGINS=http://localhost:4300,https://ops.dev.e-trinity.co.kr

