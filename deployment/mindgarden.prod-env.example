# MindGarden systemd EnvironmentFile= 예시
# 복사: sudo cp mindgarden.prod-env.example /etc/mindgarden/mindgarden.env && sudo chmod 600 ...
# 서비스: EnvironmentFile=-/etc/mindgarden/mindgarden.env
#
# OAuth: NAVER_REDIRECT_URI 미지정 시 server.base-url 사용. 네이버·카카오 콘솔 Callback과 동일 호스트 필수.
#   운영 권장: OAUTH2_BASE_URL=https://core-solution.co.kr , SERVER_BASE_URL=https://core-solution.co.kr
#   (테넌트 mindgarden.core-solution.co.kr 가 아님 — 멀티테넌트는 apex 콜백 1개 패턴)
# FRONTEND_BASE_URL: 사용자 SPA (예 https://mindgarden.core-solution.co.kr)
# 저장소에는 실비밀·실키를 넣지 말고 값은 비우거나 배포 호스트에서만 채움.

OAUTH2_BASE_URL=
FRONTEND_BASE_URL=
SERVER_BASE_URL=
# 테넌트 서브도메인 + apex OAuth 콜백 패턴에서 필수에 가깝다(미설정 시 로그인 직후 mindgarden.* 에서 401 반복 가능).
# 값: 공유할 상위 호스트만(RFC 6265 Cookie Domain: 선행 점(.) 없이 reg-name 형태, 예 core-solution.co.kr).
SESSION_COOKIE_DOMAIN=core-solution.co.kr

DB_USERNAME=
DB_PASSWORD=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google Web (server-side auth-code) — A-2 마이그레이션 (2026-06-10)
# - Google Cloud Console: https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs (Web)
# - Authorized JavaScript origins: 테넌트 서브도메인 + apex(둘 다 필요).
#   예: https://core-solution.co.kr, https://mindgarden.core-solution.co.kr,
#       https://dev.core-solution.co.kr, https://mindgarden.dev.core-solution.co.kr,
#       http://localhost:3000
# - Authorized redirect URIs: apex 1개만 등록(테넌트는 state base64 로 복원).
#   예: https://core-solution.co.kr/api/v1/auth/google/callback,
#       https://dev.core-solution.co.kr/api/v1/auth/google/callback,
#       http://localhost:8080/api/v1/auth/google/callback
# - GOOGLE_CLIENT_ID:    Web Client ID (FE 의 REACT_APP_GOOGLE_CLIENT_ID 와 동일 값 권장)
# - GOOGLE_CLIENT_SECRET: Web Client Secret — BE 토큰 교환 전용(절대 FE 노출 금지)
# - GOOGLE_REDIRECT_URI:  apex 콜백 URL — 운영은 https://core-solution.co.kr/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Sign in with Apple (SIWA) — Apple App Store 4.8 (Login Services) T1
# 가이드: docs/project-management/2026-06-04/APPLE_T1_OPS_ENV_INJECTION_GUIDE.md §1.1
# - APPLE_CLIENT_ID         : Apple Service ID (예: co.kr.coresolution.app.signin) — identityToken aud 기본값
# - APPLE_TEAM_ID           : Apple Developer Team ID (10자리)
# - APPLE_KEY_ID            : Sign in with Apple Key ID (10자리)
# - APPLE_PRIVATE_KEY       : .p8 PEM 전체 (BEGIN/END PRIVATE KEY 포함, 멀티라인)
# - APPLE_REDIRECT_URI      : Service ID 등록 Return URL
# - APPLE_ALLOWED_AUDIENCES : aud 검증 허용 List (콤마 구분).
#                             iOS 네이티브 SIWA 는 Bundle ID(com.mindgarden.MindGardenMobile),
#                             웹/Service ID 는 Service ID(co.kr.coresolution.app.signin) 로 aud 발급 →
#                             둘 모두 등록해야 앱·웹 동시 로그인 동작 (P0 hotfix 2026-06-08).
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=
APPLE_ALLOWED_AUDIENCES=

JWT_SECRET=
PERSONAL_DATA_ENCRYPTION_KEY=
PERSONAL_DATA_ENCRYPTION_IV=
PSYCH_DOC_KEY_B64=

SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

PAYMENT_TOSS_SECRET_KEY=
PAYMENT_IAMPORT_API_KEY=
PAYMENT_IAMPORT_API_SECRET=

KAKAO_ALIMTALK_API_KEY=
KAKAO_ALIMTALK_SENDER_KEY=

SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_NUMBER=

# 사용자 프로필 이미지 업로드 디렉터리 (P0 영구 대책 Phase 2 — 2026-06-09).
# blue/green 두 인스턴스가 공용으로 읽고 써야 하므로 절대경로 + 공용 폴더 필수.
# 권장: /var/mindgarden/uploads/profile-images/  (소유자: 서비스 계정, mode 755)
# 디렉터리 생성·권한·nginx client_max_body_size 설정은 다음 가이드 참고:
#   docs/project-management/2026-06-09/PROFILE_IMAGE_UPLOAD_OPS_GUIDE.md
PROFILE_IMAGE_UPLOAD_DIR=/var/mindgarden/uploads/profile-images/

# 블루그린(듀얼 systemd) 사용 시: 포트는 각 유닛의 Environment=SERVER_PORT 로만 두고, 여기서는 비워 두는 것을 권장.
# 단일 mindgarden.service 만 쓸 때만 필요 시 설정.
SERVER_PORT=
SPRING_PROFILES_ACTIVE=

SSL_KEYSTORE_PATH=
SSL_KEYSTORE_PASSWORD=
SSL_KEY_ALIAS=

# Expo 푸시: application.yml의 mindgarden.mobile.push.expo 및 Expo Push API 호출에 쓰는 액세스 토큰(호스트 env에만 설정).
EXPO_ACCESS_TOKEN=
# Push API URL. 이 줄을 생략하면 앱 기본값 사용. EXPO_PUSH_API_URL= 처럼 빈 할당은 피할 것(빈 env가 Spring 기본값을 덮어씀).
# EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
