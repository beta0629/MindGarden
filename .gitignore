# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# IDE
.idea/
*.iws
*.iml
*.ipr
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log
*.log.*

# Test data (organized)
test-data/
config/examples/
config/shell-scripts/

# Application - 민감한 설정 파일들
application-local.yml
application-prod.yml
application-production.yml
application-*.yml
# 테스트 프로파일은 저장소에서 추적(Flyway·통합 테스트 정합)
!src/test/resources/application-test.yml
*.properties
# Android local.properties는 각 개발자 환경에 따라 달라지므로 제외
mobile/android/local.properties

# Environment variables - 보안상 중요
.env
.env.*
# 예시만 커밋 (실제 비밀은 .env.local 등)
!frontend/.env.example
.env.local
.env.production
.env.staging
deployment/production-env-template.sh
deployment/*.env*

# Configuration templates with sensitive data
*-template.*
*template*
config/examples/
config/shell-scripts/
deployment/*template*

# Exception: Java source files should not be ignored even if they contain "template" in the name
!src/**/*Template.java
!src/**/*Template*.java

# Exception: Flyway migration SQL (filenames may contain "template", e.g. role_templates)
!src/main/resources/db/migration/
!src/main/resources/db/migration/*.sql

# Exception: dashboard-v2 templates folder (atomic design)
!frontend/src/components/dashboard-v2/templates/

# API Keys and Secrets
**/api-keys/
**/secrets/
**/credentials/
**/auth-keys/

# Database
*.db
*.sqlite

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Compiled class files
*.class

# Package files
*.jar
*.war
*.ear

# Virtual machine crash logs
hs_err_pid*

# Spring Boot
spring.log

# Node.js
node_modules/
package-lock.json

# --- MindGarden: 로컬·통합테스트 산출물 ---
# psych-assessments: uploads/ 하위는 기존 추적 파일이 이 경로에만 있음 — 신규 로컬 업로드만 무시
uploads/psych-assessments/

# 로컬 임시
tmp/
tmp_error_tail*.txt

# Playwright E2E 로컬 리포트: test-reports 등이 저장소에 커밋되는 정책이면 무시 패턴을 켜지 말 것(충돌).
# 로컬 산출물만 숨기려면 필요 시 아래 주석 해제.
# tests/e2e/test-results/
# tests/e2e/test-reports/

# 로컬/CI 산출물 — 저장소 비추적
test-reports/hardcoding/*.json
tests/e2e/test-reports/**
!tests/e2e/test-reports/.gitkeep
temp/cache/
temp/backups/
temp/onboarding-backup-*/
