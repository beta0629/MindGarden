import React, { useState, useEffect, useCallback } from 'react';
import { useNavigate } from 'react-router-dom';
import MGButton from '../ui';
import { useSession } from '../../contexts/SessionContext';
import { sessionManager } from '../../utils/sessionManager';
import { apiGet } from '../../utils/ajax';
import { DASHBOARD_API, API_BASE_URL } from '../../constants/api';
import { 
  Heart, 
  Calendar, 
  MessageCircle, 
  CreditCard, 
  TrendingUp,
  Clock,
  CheckCircle,
  Sparkles,
  Sun
} from 'lucide-react';
import SimpleLayout from '../layout/SimpleLayout';
import UnifiedLoading from '../ui';
import ClientPersonalizedMessages from '../dashboard/ClientPersonalizedMessages';
import ClientPaymentSessionsSection from '../dashboard/ClientPaymentSessionsSection';
import RatableConsultationsSection from './RatableConsultationsSection';
import ClientMessageSection from '../dashboard/ClientMessageSection';
import HealingCard from '../common/HealingCard';
import '../../styles/unified-design-tokens.css';
import './ClientDashboard.css';

/**
 * ΈΓ┤ΈΜ┤ΉηΡ ΈΝΑΉΜεΈ│┤ΈΥε
 * ΊβΦΉΓυΊΧαΆ│ι ΉΓ░Έε╗ΊΧε ΈΛΡΈΓΝΉζα ΈΦΦΉηΡΉζ╕Ήε╝Έκε Ά╡υΉΕ▒
 */
const ClientDashboard = () => {
  const navigate = useNavigate();
  const { user, isLoggedIn, isLoading: sessionLoading } = useSession();
  
  // sessionManagerΈκε ΉπΒΉιΣ ΊβΧΉζ╕
  const sessionUser = sessionManager.getUser();
  const sessionIsLoggedIn = sessionManager.isLoggedIn();
  
  // ΉΕ╕ΉΖα ΉηυΊβΧΉζ╕ (SNS ΈκεΆ╖╕Ήζ╕ ΉΜε ΉΕ╕ΉΖαΉζ┤ ΈκεΈΥεΈΡαΉπΑ ΉΧΛΈΛΦ Ά▓╜Ήγ░)
  useEffect(() => {
    // Ή╗┤ΊΠυΈΕΝΊΛ╕Ά░Α ΈπΙΉγ┤ΊΛ╕ΈΡε ΊδΕ ΊΧε Έ▓ΙΈπΝ ΉΜνΊΨΚ
    let isMounted = true;
    
    const checkAndRestoreSession = async () => {
      // URL ΊΝΝΈζ╝Έψ╕ΊΕ░ΉΩΡΉΕε OAuth ΉιΧΈ│┤ ΊβΧΉζ╕
      const urlParams = new URLSearchParams(window.location.search);
      const oauth = urlParams.get('oauth');
      
      if (oauth === 'success') {
        console.log('ΏθΦΩ OAuth ΈκεΆ╖╕Ήζ╕ ΉΕ▒Ά│╡, URL ΊΝΝΈζ╝Έψ╕ΊΕ░ΉΩΡΉΕε ΉΓυΉγσΉηΡ ΉιΧΈ│┤ Έ│╡ΉδΡ...');
        
        const userInfo = {
          id: parseInt(urlParams.get('userId')) || 0,
          email: urlParams.get('email') || '',
          name: decodeURIComponent(urlParams.get('name') || ''),
          nickname: decodeURIComponent(urlParams.get('nickname') || ''),
          role: urlParams.get('role') || 'CLIENT',
          profileImageUrl: decodeURIComponent(urlParams.get('profileImage') || ''),
          provider: urlParams.get('provider') || 'UNKNOWN'
        };
        
        console.log('έεΖ URL ΊΝΝΈζ╝Έψ╕ΊΕ░ΉΩΡΉΕε ΉΓυΉγσΉηΡ ΉιΧΈ│┤:', userInfo);
        
        // sessionManagerΉΩΡ ΉΓυΉγσΉηΡ ΉιΧΈ│┤ ΉΕνΉιΧ
        sessionManager.setUser(userInfo, {
          accessToken: 'oauth2_token',
          refreshToken: 'oauth2_refresh_token'
        });
        
        // URL ΊΝΝΈζ╝Έψ╕ΊΕ░ ΉιεΆ▒░
        window.history.replaceState({}, document.title, window.location.pathname);
        
        // Ή╗┤ΊΠυΈΕΝΊΛ╕Ά░Α ΉΧΕΉπΒ ΈπΙΉγ┤ΊΛ╕ΈΡαΉΨ┤ ΉηΙΉε╝Έσ┤ ΉΔΙΈκεΆ│ιΉ╣ρ
        if (isMounted) {
          console.log('ΏθΦΕ ΉΕ╕ΉΖα Έ│╡ΉδΡ ΉβΕΈμΝ, ΊΟαΉζ┤ΉπΑ ΉΔΙΈκεΆ│ιΉ╣ρ...');
          window.location.reload();
        }
        return;
      }
      
      // localStorageΉΩΡ ΉΓυΉγσΉηΡ ΉιΧΈ│┤Ά░Α ΉηΙΈΛΦΉπΑ ΊβΧΉζ╕
      const storedUser = localStorage.getItem('userInfo');
      
      if (storedUser) {
        console.log('ΏθΥο localStorageΉΩΡΉΕε ΉΓυΉγσΉηΡ ΉιΧΈ│┤ Έ░εΆ▓υ, ΉΕ╕ΉΖα Έ│╡ΉδΡ ΉΜεΈΠΕ...');
        try {
          const userInfo = JSON.parse(storedUser);
          console.log('έεΖ localStorage ΉΓυΉγσΉηΡ ΉιΧΈ│┤:', userInfo);
          
          // sessionManagerΉΩΡ ΉΓυΉγσΉηΡ ΉιΧΈ│┤ ΉΕνΉιΧ
          sessionManager.setUser(userInfo, {
            accessToken: userInfo.accessToken || 'local_token',
            refreshToken: userInfo.refreshToken || 'local_refresh_token'
          });
          
          // Ή╗┤ΊΠυΈΕΝΊΛ╕Ά░Α ΉΧΕΉπΒ ΈπΙΉγ┤ΊΛ╕ΈΡαΉΨ┤ ΉηΙΉε╝Έσ┤ ΉΔΙΈκεΆ│ιΉ╣ρ
          if (isMounted) {
            console.log('ΏθΦΕ ΉΕ╕ΉΖα Έ│╡ΉδΡ ΉβΕΈμΝ, ΊΟαΉζ┤ΉπΑ ΉΔΙΈκεΆ│ιΉ╣ρ...');
            window.location.reload();
          }
          return;
        } catch (error) {
          console.error('έζΝ localStorage ΉΓυΉγσΉηΡ ΉιΧΈ│┤ ΊΝΝΉΜ▒ ΉΜνΊΝρ:', error);
        }
      }
      
      // localStorageΉΩΡ ΉιΧΈ│┤Ά░Α ΉΩΗΉε╝Έσ┤ ΉΧΕΈυ┤Ά▓ΔΈΠΕ ΊΧαΉπΑ ΉΧΛΆ│ι ΈΝΑΆ╕░
      console.log('έΠ│ localStorageΉΩΡ ΉΓυΉγσΉηΡ ΉιΧΈ│┤Ά░Α ΉΩΗΉζΝ, ΉΕ╕ΉΖα ΈκεΈΦσ ΈΝΑΆ╕░ ΉνΣ...');
    };
    
    // ΉΕ╕ΉΖαΉζ┤ ΉΧΕΉπΒ ΈκεΈΥεΈΡαΉπΑ ΉΧΛΉΧαΉζΕ ΈΧΝΈπΝ ΉΕ╕ΉΖα ΉηυΊβΧΉζ╕
    if (!sessionIsLoggedIn && !sessionUser) {
      console.log('έΠ│ ΉΕ╕ΉΖαΉζ┤ ΈκεΈΥεΈΡαΉπΑ ΉΧΛΉζΝ, ΉΕ╕ΉΖα ΉηυΊβΧΉζ╕ ΉΜεΉηΣ...');
      
      // ΉΧ╜Ά░ΕΉζα ΉπΑΉΩ░ ΊδΕ ΉΕ╕ΉΖα ΊβΧΉζ╕ (Έ░▒ΉΩΦΈΥε ΈουΈΜνΉζ┤ΈιΚΊΛ╕ ΉβΕΈμΝ ΈΝΑΆ╕░)
      const timer = setTimeout(() => {
        checkAndRestoreSession();
      }, 500);
      
      return () => {
        isMounted = false;
        clearTimeout(timer);
      };
    }
    
    return () => {
      isMounted = false;
    };
  }, [sessionIsLoggedIn, sessionUser]);
  
  const [currentTime, setCurrentTime] = useState('');
  const [consultationData, setConsultationData] = useState({
    todaySchedules: [],
    weeklySchedules: [],
    upcomingSchedules: [],
    completedCount: 0,
    totalSessions: 0,
    usedSessions: 0,
    remainingSessions: 0
  });
  const [clientStatus, setClientStatus] = useState(null);
  const [isLoading, setIsLoading] = useState(true);

  // ΊαΕΉηυ ΉΜεΆ░Ε ΉΩΖΈΞ░Ήζ┤ΊΛ╕
  useEffect(() => {
    const updateTime = () => {
      const now = new Date();
      const hours = now.getHours();
      const minutes = now.getMinutes().toString().padStart(2, '0');
      const period = hours < 12 ? 'ΉανΉιΕ' : 'ΉανΊδΕ';
      const displayHours = hours % 12 || 12;
      setCurrentTime(`${period} ${displayHours}:${minutes}`);
    };

    updateTime();
    const interval = setInterval(updateTime, 60000);
    return () => clearInterval(interval);
  }, []);

  // ΈΓ┤ΈΜ┤ΉηΡ ΈΞ░Ήζ┤ΊΕ░ ΈκεΈΥε
  const loadClientData = useCallback(async () => {
    // sessionUser ΈαΡΈΛΦ user ΈΣα ΉνΣ ΊΧαΈΓαΈζ╝ΈΠΕ ΉηΙΉε╝Έσ┤ ΉπΕΊΨΚ
    const currentUser = sessionUser || user;
    if (!currentUser?.id) {
      return;
    }

    try {
      setIsLoading(true);

      // ΉΛνΉ╝ΑΉνΕ ΈΞ░Ήζ┤ΊΕ░ ΈκεΈΥε
      const scheduleResponse = await apiGet(DASHBOARD_API.CLIENT_SCHEDULES, {
        userId: currentUser.id,
        userRole: 'CLIENT'
      });

      // ΈπνΊΧΣ ΉιΧΈ│┤ ΈκεΈΥε (ΉΜνΉιε ΊγΝΆ╕░ ΉΙαΈξ╝ Ά░ΑΉι╕ΉανΆ╕░ ΉεΕΊΧ┤)
      const mappingResponse = await apiGet(`/api/admin/mappings/client?clientId=${currentUser.id}`);

      let totalSessions = 0;
      let usedSessions = 0;
      let remainingSessions = 0;

      // ΈπνΊΧΣ ΉιΧΈ│┤ΉΩΡΉΕε ΉΜνΉιε ΊγΝΆ╕░ ΉΙα Ά│ΕΉΓ░
      if (mappingResponse?.success && mappingResponse?.data) {
        const activeMappings = mappingResponse.data.filter(mapping => mapping.status === 'ACTIVE');
        totalSessions = activeMappings.reduce((sum, mapping) => sum + (mapping.totalSessions || 0), 0);
        usedSessions = activeMappings.reduce((sum, mapping) => sum + (mapping.usedSessions || 0), 0);
        remainingSessions = activeMappings.reduce((sum, mapping) => sum + (mapping.remainingSessions || 0), 0);
      }

      if (scheduleResponse?.success && scheduleResponse?.data) {
        const schedules = scheduleResponse.data;
        const today = new Date();
        const todayStr = today.toISOString().split('T')[0];

        // ΉανΈΛαΉζα ΉΔΒΈΜ┤
        const todaySchedules = schedules.filter(s => s.date === todayStr);

        // Ήζ┤Έ▓Ι Ήμ╝ ΉΔΒΈΜ┤
        const startOfWeek = new Date(today);
        startOfWeek.setDate(today.getDate() - today.getDay());
        const endOfWeek = new Date(today);
        endOfWeek.setDate(today.getDate() + (6 - today.getDay()));
        
        const weeklySchedules = schedules.filter(schedule => {
          const scheduleDate = new Date(schedule.date);
          return scheduleDate >= startOfWeek && scheduleDate <= endOfWeek;
        });

        // ΈΜνΆ░ΑΉανΈΛΦ ΉΔΒΈΜ┤
        const upcomingSchedules = schedules.filter(schedule => {
          const scheduleDate = new Date(schedule.date);
          return scheduleDate > today && schedule.status === 'CONFIRMED';
        }).slice(0, 3);

        // ΉβΕΈμΝΈΡε ΉΔΒΈΜ┤ ΉΙα
        const completedCount = schedules.filter(s => s.status === 'COMPLETED').length;

        setConsultationData({
          todaySchedules,
          weeklySchedules,
          upcomingSchedules,
          completedCount,
          totalSessions, // ΈπνΊΧΣ ΉιΧΈ│┤ΉΩΡΉΕε Ά░ΑΉι╕Ήαρ Ά░Τ
          usedSessions, // ΈπνΊΧΣ ΉιΧΈ│┤ΉΩΡΉΕε Ά░ΑΉι╕Ήαρ Ά░Τ
          remainingSessions // ΈπνΊΧΣ ΉιΧΈ│┤ΉΩΡΉΕε Ά░ΑΉι╕Ήαρ Ά░Τ (ΉΜνΉιε Ά╡υΈπνΊΧε ΊγΝΆ╕░ ΉΙα)
        });
      } else {
        // ΉΛνΉ╝ΑΉνΕ ΉιΧΈ│┤Ά░Α ΉΩΗΉΨ┤ΈΠΕ ΊγΝΆ╕░ ΉιΧΈ│┤ΈΛΦ ΊΣεΉΜε
        setConsultationData(prev => ({
          ...prev,
          totalSessions,
          usedSessions,
          remainingSessions
        }));
      }

    } catch (error) {
      console.error('έζΝ ΈΓ┤ΈΜ┤ΉηΡ ΈΞ░Ήζ┤ΊΕ░ ΈκεΈΥε ΉΜνΊΝρ:', error);
    } finally {
      setIsLoading(false);
    }
  }, [user?.id, sessionUser?.id]);

  useEffect(() => {
    // ΉΕ╕ΉΖαΉζ┤ ΈκεΈΦσ ΉνΣΉζ┤Έσ┤ ΈΝΑΆ╕░
    if (sessionLoading) {
      return;
    }
    
    // sessionManagerΈκε ΉπΒΉιΣ ΊβΧΉζ╕
    const currentUser = sessionUser || user;
    const currentIsLoggedIn = sessionIsLoggedIn || isLoggedIn;
    
    if (currentIsLoggedIn && currentUser?.id) {
      loadClientData();
    }
  }, [sessionLoading, sessionIsLoggedIn, sessionUser?.id, user?.id, loadClientData]);

  // ΈκεΈΦσ ΉΔΒΊΔε ΈαΡΈΛΦ ΈκεΆ╖╕Ήζ╕ΊΧαΉπΑ ΉΧΛΉζΑ Ά▓╜Ήγ░
  const currentUser = sessionUser || user;
  const currentIsLoggedIn = sessionIsLoggedIn || isLoggedIn;
  
  // ΉΕ╕ΉΖα ΈκεΈΦσ ΉνΣΉζ┤Ά▒░ΈΓα, ΉΕ╕ΉΖαΉζ┤ ΉΧΕΉπΒ ΈκεΈΥεΈΡαΉπΑ ΉΧΛΉΧαΆ▒░ΈΓα, ΉΓυΉγσΉηΡ ΉιΧΈ│┤Ά░Α ΉΩΗΉε╝Έσ┤ ΈκεΈΦσ ΊΣεΉΜε
  if (isLoading || sessionLoading || !currentIsLoggedIn || !currentUser?.id) {
    return (
      <SimpleLayout>
        <div className="mg-v2-dashboard-layout">
          <UnifiedLoading text="ΈΝΑΉΜεΈ│┤ΈΥεΈξ╝ Έ╢ΙΈθυΉανΈΛΦ ΉνΣ..." />
        </div>
      </SimpleLayout>
    );
  }

  // Ήζ╕ΉΓυΈπΡ ΈσΦΉΜεΉπΑ
  const getGreeting = () => {
    const hour = new Date().getHours();
    if (hour < 12) return 'ΉλΜΉζΑ ΉΧΕΉ╣ρΉζ┤ΉΩΡΉγΦ';
    if (hour < 18) return 'ΉλΜΉζΑ ΉανΊδΕΉΩΡΉγΦ';
    return 'ΉλΜΉζΑ ΉιΑΈΖΒΉζ┤ΉΩΡΉγΦ';
  };

  return (
    <SimpleLayout>
      <div className="mg-v2-dashboard-layout">
        
        {/* Ήδ░Ή╗┤ ΊΩνΈΞΦ - ΊβΦΉΓυΊΧαΆ│ι Έ░ζΉζΑ ΈΛΡΈΓΝ */}
        <div className="mg-v2-client-dashboard-header">
          <div className="mg-v2-dashboard-header-content">
            <div className="mg-v2-flex mg-align-center mg-gap-md">
              <div className="mg-v2-dashboard-icon">
                <Sun size={32} />
              </div>
              <div>
                <h1 className="mg-v2-h1">
                  {getGreeting()}, <span className="mg-v2-color-primary">{currentUser?.name}</span>ΈΜα!
                </h1>
                <p className="mg-v2-text-sm mg-v2-color-text-secondary mg-mt-xs">
                  <Sparkles size={16} className="mg-v2-mr-xs" />
                  ΉανΈΛαΈΠΕ ΈπΙΉζΝ Ά▒┤Ά░ΧΉζΕ ΉεΕΊΧε ΊΧε Ά▒╕ΉζΝΉζΕ ΊΧρΆ╗αΊΧ┤ΉγΦ
                </p>
              </div>
            </div>
            <div className="mg-v2-flex mg-align-center mg-gap-sm">
              <Clock size={18} />
              <span className="mg-v2-text-sm">{currentTime}</span>
            </div>
          </div>
        </div>

        {/* Ήμ╝ΉγΦ ΊΗ╡Ά│Ε Ή╣┤ΈΥε - Έ░ζΆ│ι ΊβΦΉΓυΊΧε ΉΔΚΉΔΒ */}
        <div className="client-dashboard__stats">
          <div className="client-dashboard__stat-card client-dashboard__stat-card--primary">
            <div className="client-dashboard__stat-icon">
              <Calendar />
            </div>
            <div className="client-dashboard__stat-content">
              <div className="client-dashboard__stat-value">
                {consultationData.todaySchedules.length}
              </div>
              <div className="client-dashboard__stat-label">ΉανΈΛαΉζα ΉΔΒΈΜ┤</div>
            </div>
          </div>

          <div className="client-dashboard__stat-card client-dashboard__stat-card--success">
            <div className="client-dashboard__stat-icon">
              <CheckCircle />
            </div>
            <div className="client-dashboard__stat-content">
              <div className="client-dashboard__stat-value">
                {consultationData.completedCount}
              </div>
              <div className="client-dashboard__stat-label">ΉβΕΈμΝΊΧε ΉΔΒΈΜ┤</div>
            </div>
          </div>

          <div className="client-dashboard__stat-card client-dashboard__stat-card--info">
            <div className="client-dashboard__stat-icon">
              <TrendingUp />
            </div>
            <div className="client-dashboard__stat-content">
              <div className="client-dashboard__stat-value">
                {consultationData.weeklySchedules.length}
              </div>
              <div className="client-dashboard__stat-label">Ήζ┤Έ▓Ι Ήμ╝ ΉΔΒΈΜ┤</div>
            </div>
          </div>

          <div className="client-dashboard__stat-card client-dashboard__stat-card--warning">
            <div className="client-dashboard__stat-icon">
              <Heart />
            </div>
            <div className="client-dashboard__stat-content">
              <div className="client-dashboard__stat-value">
                {consultationData.remainingSessions}
              </div>
              <div className="client-dashboard__stat-label">ΈΓρΉζΑ ΊγΝΆ╕░</div>
            </div>
          </div>
        </div>

        {/* ΈΜνΆ░ΑΉανΈΛΦ ΉΔΒΈΜ┤ Ήζ╝ΉιΧ */}
        {consultationData.upcomingSchedules.length > 0 && (
          <div className="client-dashboard__section">
            <div className="client-dashboard__section-header">
              <h2 className="client-dashboard__section-title">
                <Calendar size={24} />
                ΈΜνΆ░ΑΉανΈΛΦ ΉΔΒΈΜ┤ Ήζ╝ΉιΧ
              </h2>
            </div>
            <div className="client-dashboard__schedule-list">
              {consultationData.upcomingSchedules.map((schedule, index) => (
                <div key={index} className="client-dashboard__schedule-item">
                  <div className="client-dashboard__schedule-date">
                    <div className="client-dashboard__schedule-day">
                      {new Date(schedule.date).getDate()}
                    </div>
                    <div className="client-dashboard__schedule-month">
                      {new Date(schedule.date).toLocaleDateString('ko-KR', { month: 'short' })}
                    </div>
                  </div>
                  <div className="client-dashboard__schedule-info">
                    <h3 className="client-dashboard__schedule-title">{schedule.title}</h3>
                    <p className="client-dashboard__schedule-time">
                      <Clock size={14} />
                      {schedule.startTime} - {schedule.endTime}
                    </p>
                  </div>
                  <div className="client-dashboard__schedule-status">
                    <span className="mg-badge mg-badge-success">ΉαΙΉιΧ</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ΈπηΉ╢νΊαΧ ΈσΦΉΜεΉπΑ */}
        <ClientPersonalizedMessages 
          user={user}
          consultationData={consultationData}
          clientStatus={clientStatus}
        />

        {/* Ά▓░Ήιε Έ░Π ΊγΝΆ╕░ ΊαΕΊβσ */}
        <ClientPaymentSessionsSection userId={currentUser?.id} />

        {/* ΉΔΒΈΜ┤ΉΓυ ΊΠΚΆ░Α */}
        <RatableConsultationsSection />

        {/* ΉανΈΛαΉζα ΊηΡΈπΒ Ή╣┤ΈΥε */}
        <HealingCard userRole="CLIENT" />

        {/* Έ╣ιΈξ╕ ΉΧκΉΖα Έ▓ΕΊΛ╝ */}
        <div className="client-dashboard__quick-actions">
          <h2 className="client-dashboard__section-title">Έ╣ιΈξ╕ ΈσΦΈΚ┤</h2>
          <div className="client-dashboard__action-grid">
            <MGButton 
              variant="primary"
              fullWidth={true}
              onClick={() => navigate('/client/schedule')}
              className="client-dashboard__action-btn"
            >
              <Calendar size={24} />
              <span>ΉΔΒΈΜ┤ Ήζ╝ΉιΧ</span>
            </MGButton>
            <MGButton 
              variant="success"
              fullWidth={true}
              onClick={() => navigate('/client/messages')}
              className="client-dashboard__action-btn"
            >
              <MessageCircle size={24} />
              <span>ΈσΦΉΜεΉπΑ</span>
            </MGButton>
            <MGButton 
              variant="info"
              fullWidth={true}
              onClick={() => navigate('/client/payment-history')}
              className="client-dashboard__action-btn"
            >
              <CreditCard size={24} />
              <span>Ά▓░Ήιε ΈΓ┤ΉΩφ</span>
            </MGButton>
            <MGButton 
              variant="warning"
              fullWidth={true}
              onClick={() => navigate('/client/settings')}
              className="client-dashboard__action-btn"
            >
              <Heart size={24} />
