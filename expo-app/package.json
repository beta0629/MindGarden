{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "prestart": "npm run verify:metro-mmkv",
    "prestart:clean": "npm run verify:metro-mmkv",
    "start": "expo start",
    "start:clean": "expo start --clear",
    "verify:metro-mmkv": "node ./scripts/verify-metro-mmkv.js",
    "verify:bundle:ci": "npm run verify:metro-mmkv && CI=1 npx expo export --platform web --output-dir /tmp/mg-expo-ci-web",
    "start:localhost": "expo start --localhost",
    "ios:metro-localhost": "xcrun simctl openurl booted \"mindgarden://expo-development-client/?url=http%3A%2F%2F127.0.0.1%3A8081\"",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
